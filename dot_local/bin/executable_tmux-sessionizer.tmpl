#!/usr/bin/env bash

PATH="$HOME/.config/fzf/bin:$HOME/.local/bin:$PATH"
tmux_layout="$HOME/.local/bin/tmux-layout"

if [[ $# -eq 1 ]]; then
    root_dir=~
    selected=$1
else
    root_dir=~/dev
    selected=$(find "$root_dir/" -mindepth 1 -maxdepth 1 -type d | xargs -L1 -I{} basename "{}" | sort | fzf)
fi

if [[ -z $selected ]]; then
    exit 0
fi

tmux_running=$(pgrep tmux)
selected_root="$root_dir/$selected"

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -ds "$selected" -c "$selected_root"
    "$tmux_layout" "$selected" "$selected_root"
    tmux attach-session -t "$selected"
    #base16_chalk
    exit 0
fi

if ! tmux has-session -t="$selected" 2> /dev/null; then
    tmux new-session -ds "$selected" -c "$selected_root"
    "$tmux_layout" "$selected" "$selected_root"
fi

if [[ -z $TMUX ]]; then
    tmux attach-session -t "$selected"
else
    tmux switch-client -t "$selected"
fi
#base16_chalk
