#!/usr/bin/env bash

session=${1:-$(tmux display-message -p '#S')}
dir=${2:-$(tmux display-message -p -t "$session:0.0" '#{pane_current_path}')}

# Kill all panes except the first
while tmux kill-pane -t "$session:0.1" 2>/dev/null; do :; done

# tmux percentage sizing is broken on Ubuntu, requiring a smaller value to get ~40% visually
tmux split-window -t "$session:0.0" -h -c "$dir"
tmux resize-pane -t "$session:0.1" -x {{ if eq .chezmoi.osRelease.id "ubuntu" }}10%{{ else }}40%{{ end }}
tmux split-window -t "$session:0.1" -v -c "$dir"
tmux send-keys -t "$session:0.1" 'claude --continue' Enter
tmux select-pane -t "$session:0.0"
tmux send-keys -t "$session:0.0" 'nvim' Enter
