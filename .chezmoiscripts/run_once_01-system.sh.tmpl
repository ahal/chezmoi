#!/bin/bash
set -euo pipefail

mkdir -p "$HOME/bin"

{{ if eq .chezmoi.osRelease.id "fedora" -}}
sudo dnf install -y \
  ddcutil \
  direnv \
  gcc \
  libxcb-devel \
  git \
{{ if not .enable_mozilla -}}
  mangohud \
{{ end -}}
  meld \
  openssl-devel \
  pkgconf-pkg-config \
  python3-devel \
  tmux \
  zsh
{{ else if eq .chezmoi.osRelease.id "ubuntu" -}}
sudo apt-get install -y \
  build-essential \
  ddcutil \
  direnv \
  libxcb1-dev \
  libxcb-render0-dev \
  libxcb-shape0-dev \
  libxcb-xfixes0-dev \
  git \
{{ if not .enable_mozilla -}}
  mangohud \
{{ end -}}
  libssl-dev \
  meld \
  pkg-config \
  scdaemon \
  tmux \
  zsh
{{ end -}}

# tmux plugin manager
if [ ! -d "$HOME/.tmux/plugins/tpm" ]; then
  git clone --branch master https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm"
fi
