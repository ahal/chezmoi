[user]
name = "Andrew Halberstadt"
{{ if .enable_mozilla -}}
email = "ahal@mozilla.com"
{{ else -}}
email = "ahal@pm.me"
{{ end -}}

[signing]
behavior = "own"
backend = "gpg"
{{ if .enable_mozilla -}}
key = "83871F16BEF61C4F2CA5CFFE186B1CE58780653F"
{{ else -}}
key = "5DD9F0C21329EA09A0A3F238F09CA0E91C1042EC"
{{ end -}}

[git]
push = "ahal"
fetch = ["origin", "ahal"]

[fsmonitor]
backend = "watchman"

[fsmonitor.watchman]
register-snapshot-trigger = false

[aliases]
heads = ["log", "-r", "visible_heads() & mutable()", "-T", "builtin_log_compact", "--no-graph"]
shortlog = ["log", "--limit=12"]
tug = ["bookmark", "move", "--from", "heads(::@- & bookmarks())", "--to", "latest(::@ ~ empty())"]
remote-add = ["util", "exec", "--", "bash", "-c", """
if [ -z "$1" ] || [ -z "$2" ]; then
    echo "Usage: jj remote-add <name> <owner/slug>"
    exit 1
fi
set -euo pipefail
jj git remote add "$1" "https://github.com/$2"
jj git remote set-url "$1" --push "git@github.com:$2.git"
""", ""]
clone-repo = ["util", "exec", "--", "bash", "-c", """
set -euo pipefail
if [[ $# -ne 1 ]] || [[ "$1" != */* ]]; then
    echo "Usage: jj clone-repo <owner/repo>" >&2
    exit 1
fi
owner="${1%%/*}"
repo="${1#*/}"
url="https://github.com/${owner}/${repo}"
dest="$HOME/dev/${repo}"
jj git clone --colocate "$url" "$dest"
cd "$dest"
jj git remote set-url origin --push "git@github.com:${owner}/${repo}.git"
if [[ "$owner" == "ahal" ]]; then
    jj config set --repo git.fetch '["origin"]'
    jj config set --repo git.push '"origin"'
else
    if [[ "$url" =~ github\\.com ]]; then
        ahal_http_url="https://github.com/ahal/${repo}"
        if git ls-remote "$ahal_http_url" HEAD &>/dev/null; then
            jj remote-add ahal "ahal/${repo}"
        fi
    fi
fi
""", ""]
pull = ["util", "exec", "--", "bash", "-c", """
if [ -z "$1" ]; then
    echo "missing branch"
    exit 1
fi
set -euo pipefail
jj git fetch -b $1
jj rebase -s "at_operation(@-, $1+) & mutable()" -d $1
""", ""]

[colors]
bookmarks = "green"
change_id = "blue"
"diff removed token" = { underline = false }
"diff added token" = { underline = false }
"node immutable" = "red"
"working_copy bookmarks" = "green"
"working_copy change_id" = "blue"

[revsets]
log = "present(@) | trunk() | ancestors(immutable_heads().. ~ ::untracked_remote_bookmarks(), 2)"

[revset-aliases]
"feat(x)" = "::x ~ immutable()"

[template-aliases]
"format_short_signature(signature)" = 'signature.email().local()'
"link(target, label)" = 'raw_escape_sequence("\x1b]8;;" ++ target ++ "\x1b\\") ++ label ++ raw_escape_sequence("\x1b]8;;\x1b\\")'
"slugify(str)" = '''
  truncate_end(
    65,
    str.first_line()
      .replace(regex:'[^[[:alnum:]].]', '-')
      .replace(regex:'-{2,}', '-')
      .replace(regex:'\.{2,}', '.')
      .replace(regex:'(^-+|-+$)', '')
      .lower()
  )
'''

[templates]
git_push_bookmark = '"ahal/" ++ slugify(description) ++ "/" ++ change_id.short()'

[ui]
default-command = "shortlog"
editor = "/home/ahal/opt/neovim/bin/nvim"
merge-editor = ["meld", "$left", "$base", "$right", "-o", "$output", "--auto-merge"]
diff-formatter = ":git"

[ui.movement]
edit = true
